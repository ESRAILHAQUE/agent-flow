# ============================================================
# AgentFlow API — Environment Variables
# ============================================================

# Server
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://agentflow:agentflow_dev_2024@localhost:5432/agentflow

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=agentflow-access-secret-change-in-production
JWT_REFRESH_SECRET=agentflow-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# OpenAI / OpenRouter
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LLM_PROVIDER=openrouter

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@agentflow.io

# File Storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
